# Copy this file to .env.local and fill in your values

# ── Sui Network ──────────────────────────────────────────────────────────────
# Options: mainnet | testnet | devnet | localnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Your deployed Move package ID (after `sui client publish`)
NEXT_PUBLIC_PACKAGE_ID=0xYOUR_PACKAGE_ID_HERE

# ── zkLogin ───────────────────────────────────────────────────────────────────
# Google OAuth client ID (create at console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Redirect URI registered in Google OAuth (must match exactly)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# Mysten Labs prover service for zkLogin
NEXT_PUBLIC_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# ── Walrus ────────────────────────────────────────────────────────────────────
# Walrus publisher endpoint (testnet)
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Walrus aggregator endpoint (testnet) — used to retrieve stored blobs
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
